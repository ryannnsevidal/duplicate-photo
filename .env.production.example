# Production Environment Configuration Template
# Copy to .env.production and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Google OAuth & API Configuration
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_API_KEY=xxxxxxxxxx
GOOGLE_CLIENT_SECRET=xxxxxxxxxx

# Dropbox API Configuration
VITE_DROPBOX_APP_KEY=xxxxxxxxxxxx
DROPBOX_APP_SECRET=xxxxxxxxxx

# reCAPTCHA Configuration (Optional)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Application Configuration
VITE_APP_NAME=PIX DUPE DETECT
VITE_APP_URL=https://your-domain.com
VITE_APP_ENVIRONMENT=production

# File Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp
VITE_MAX_FILES_PER_UPLOAD=10

# Session Configuration
VITE_SESSION_TIMEOUT=1800
VITE_ACTIVITY_CHECK_INTERVAL=60000

# Security Configuration
VITE_ENABLE_CSRF_PROTECTION=true
VITE_ENABLE_RATE_LIMITING=true
VITE_MAX_LOGIN_ATTEMPTS=5

# Analytics Configuration (Optional)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=phc_xxxxxxxxxx
VITE_SENTRY_DSN=https://xxxxxxxxxx.ingest.sentry.io/xxxxxxxxxx

# Feature Flags
VITE_ENABLE_CLOUD_STORAGE=true
VITE_ENABLE_ADMIN_DASHBOARD=true
VITE_ENABLE_AUDIT_LOGGING=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=false

# Performance Configuration
VITE_IMAGE_PROCESSING_WORKER_COUNT=4
VITE_HASH_PROCESSING_CHUNK_SIZE=1000
VITE_DUPLICATE_CHECK_BATCH_SIZE=50

# Development/Debug (set to false in production)
VITE_DEBUG_MODE=false
VITE_ENABLE_CONSOLE_LOGS=false
VITE_SHOW_PERFORMANCE_METRICS=false
