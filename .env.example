# 🔍 Duplicate Photo Detector - Environment Configuration

# 🚀 SUPABASE CONFIGURATION (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 🔐 AUTHENTICATION & SECURITY
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ☁️ CLOUD STORAGE APIS (Optional - can be stubbed)
VITE_DROPBOX_APP_KEY=your-dropbox-app-key
VITE_GDRIVE_CLIENT_ID=your-google-drive-client-id
GDRIVE_CLIENT_SECRET=your-google-drive-client-secret

# ️ SECURITY SETTINGS
JWT_SECRET_KEY=your-super-secret-jwt-key-here
ENCRYPTION_KEY=your-32-character-encryption-key
SESSION_TIMEOUT_MINUTES=30
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,bmp,tiff

# 🔧 API CONFIGURATION
VITE_API_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# 🚀 DEPLOYMENT SETTINGS
NODE_ENV=development
VITE_APP_TITLE=Duplicate Photo Detector
VITE_APP_DESCRIPTION=Enterprise-grade duplicate photo detection with AI

# 📊 ANALYTICS & MONITORING (Optional)
VITE_SENTRY_DSN=your-sentry-dsn-here
VITE_GOOGLE_ANALYTICS_ID=your-ga-id

# 🎯 FEATURE FLAGS
VITE_ENABLE_GOOGLE_DRIVE=true
VITE_ENABLE_DROPBOX=true
VITE_ENABLE_LOCAL_UPLOAD=true
VITE_ENABLE_ADMIN_PANEL=true
VITE_ENABLE_DUPLICATE_DETECTION=true
VITE_ENABLE_FILE_PREVIEW=true

# ⚡ PERFORMANCE SETTINGS
VITE_MAX_CONCURRENT_UPLOADS=5
VITE_DUPLICATE_CHECK_BATCH_SIZE=100
VITE_IMAGE_PROCESSING_QUALITY=85
VITE_THUMBNAIL_SIZE=150

# � RATE LIMITING
VITE_RATE_LIMIT_REQUESTS_PER_MINUTE=60
VITE_RATE_LIMIT_BURST=10

# 🎨 UI/UX SETTINGS
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true
VITE_SHOW_TUTORIAL=true

# 🔧 DEVELOPMENT TOOLS
VITE_ENABLE_DEV_TOOLS=true
VITE_SHOW_DEBUG_INFO=false
